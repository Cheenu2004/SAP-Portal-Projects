<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    <Dialog title="Change Password" id="changePasswordDialog" class="sapUiPopupWithPadding">
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Employee ID" required="true" class="sapUiTinyMarginBottom" design="Bold"/>
                <Input id="cpUserIdInput" placeholder="Enter Employee ID" class="sapUiSmallMarginBottom customInputStyle"/>
                
                <Label text="Current Password" required="true" class="sapUiTinyMarginBottom" design="Bold"/>
                <Input id="cpCurrentPasswordInput" type="Password" placeholder="Enter Current Password" class="sapUiSmallMarginBottom customInputStyle"/>
                
                <Label text="New Password" required="true" class="sapUiTinyMarginBottom" design="Bold"/>
                <Input id="cpNewPasswordInput" type="Password" placeholder="Enter New Password" class="customInputStyle"/>
                
                <MessageStrip id="cpMessageStrip" text="" type="Error" showIcon="true" visible="false" class="sapUiSmallMarginTop"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Change Password" type="Emphasized" press="onChangePasswordSubmit"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onChangePasswordCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
