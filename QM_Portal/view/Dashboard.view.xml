<mvc:View
    controllerName="qmportal1.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <mvc:dependents>
        <Dialog
            id="logoutDialog"
            contentWidth="320px">
            
            <customHeader>
                <Bar class="qmPurpleHeader">
                    <contentMiddle>
                        <Title text="Confirm Logout"/>
                    </contentMiddle>
                </Bar>
            </customHeader>

            <content>
                <VBox class="sapUiMediumMargin" alignItems="Center">
                    <Text text="Are you sure you want to logout?" textAlign="Center" class="sapUiSmallMarginBottom"/>
                </VBox>
            </content>

            <buttons>
                <Button
                    text="Yes"
                    type="Emphasized"
                    press="onConfirmLogout"/>
                <Button
                    text="No"
                    type="Transparent"
                    press="onCancelLogout"/>
            </buttons>
        </Dialog>
    </mvc:dependents>

    <Page title="Quality Management Dashboard">



        <headerContent>
            <HBox alignItems="Center" class="qmHeaderUserBar">
                <!-- Person icon -->
                <core:Icon
                    src="sap-icon://person-placeholder"
                    class="qmHeaderUserIcon"
                    xmlns:core="sap.ui.core"/>
                <!-- User ID -->
                <Text
                    id="hdrUserId"
                    text=""
                    class="qmHeaderUserText"/>
                <!-- Role pill -->
                <Label
                    id="hdrUserRole"
                    text=""
                    class="qmHeaderRolePill"/>
                <!-- Logout -->
                <Button
                    text="Logout"
                    icon="sap-icon://log"
                    type="Emphasized"
                    class="qmLogoutBtn"
                    press="onLogout"/>
            </HBox>
        </headerContent>

        <content>

            <!-- Centered tile area: fills full page height, tiles centered -->
            <VBox
                height="100%"
                justifyContent="Center"
                alignItems="Center"
                class="qmDashboardCenter">

                <HBox
                    justifyContent="Center"
                    alignItems="Center"
                    wrap="Wrap"
                    class="qmTileRow">

                    <GenericTile
                        header="Inspection Lots"
                        subheader="Active inspection lots"
                        press="onInspectionLotPress"
                        class="qmDashTile"
                        frameType="TwoByOne">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="IL"
                                        icon="sap-icon://quality-issue"
                                        withMargin="false"/>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <GenericTile
                        header="Result Records"
                        subheader="Recorded results"
                        press="onResultRecordPress"
                        class="qmDashTile"
                        frameType="TwoByOne">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="RR"
                                        icon="sap-icon://document-text"
                                        withMargin="false"/>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <GenericTile
                        header="Usage Decisions"
                        subheader="Decisions recorded"
                        press="onUsageDecisionPress"
                        class="qmDashTile"
                        frameType="TwoByOne">
                        <tileContent>
                            <TileContent>
                                <content>
                                    <NumericContent
                                        value="UD"
                                        icon="sap-icon://decision"
                                        withMargin="false"/>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                </HBox>

            </VBox>

        </content>

    </Page>

</mvc:View>